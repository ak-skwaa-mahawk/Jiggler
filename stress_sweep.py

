import numpy as np
import matplotlib.pyplot as plt
import json
import time
from tordial_gs_v13 import DualRingTordialMatrix

def run_stress_test(node_count=24, cycles=300, mode="open"):
    """Run stress test with both general + toric-code topological metrics."""
    print(f"\n=== Stress Sweep: {mode.upper()} MODE | Nodes={node_count} | Cycles={cycles} ===")

    matrix = DualRingTordialMatrix(node_count=node_count, agent_mode=True)

    collapse_events = 0
    fission_events = 0
    sigma_history = []
    node_count_history = []
    logical_error_history = []
    anyon_count_history = []

    start_time = time.time()

    for c in range(cycles):
        # Varying load
        load = 1.0 + 0.55 * np.sin(c / 18)
        matrix.execute_heavy_load_cycle(system_load=load)

        current_nodes = len(matrix.nodes_a)
        node_count_history.append(current_nodes)

        # Sigma_T statistics
        sigmas = [getattr(n, 'sigma_T', 0) for n in matrix.nodes_a if hasattr(n, 'sigma_T')]
        avg_sigma = np.mean(sigmas) if sigmas else 0
        sigma_history.append(avg_sigma)

        if avg_sigma < -800:
            collapse_events += 1

        # Fission tracking
        fission_events += sum(getattr(n, 'fission_count', 0) for n in matrix.nodes_a)

        # Topological / Toric metrics
        ler = getattr(matrix, 'logical_error_rate', 0.0)
        logical_error_history.append(ler)
        
        anyon_count = len(getattr(matrix, 'anyons', []))
        anyon_count_history.append(anyon_count)

        if c % 50 == 0:
            print(f"Cycle {c:4d} | Nodes: {current_nodes:4d} | "
                  f"Avg σ_T: {avg_sigma:8.2f} | LER: {ler:.4f} | Anyons: {anyon_count}")

    duration = time.time() - start_time

    results = {
        "mode": mode,
        "final_nodes": current_nodes,
        "collapse_events": collapse_events,
        "total_fissions": fission_events,
        "avg_sigma": float(np.mean(sigma_history)),
        "max_nodes": max(node_count_history),
        "avg_logical_error_rate": float(np.mean(logical_error_history)),
        "max_logical_error_rate": float(max(logical_error_history)),
        "avg_anyon_count": float(np.mean(anyon_count_history)),
        "duration_sec": round(duration, 2)
    }

    print(f"→ Final Nodes: {results['final_nodes']} | Collapses: {collapse_events} | "
          f"Fissions: {fission_events} | Avg LER: {results['avg_logical_error_rate']:.4f}")
    return results


def compare_all():
    """Run full comparison: Bounded vs Open (Infinite Loophole) with Toric metrics."""
    print("Running Bounded vs Open Topological Stress Comparison...\n")

    bounded = run_stress_test(mode="bounded")
    open_mode = run_stress_test(mode="open")

    # === Plotting ===
    fig, axs = plt.subplots(2, 3, figsize=(18, 10))

    # Node Growth
    axs[0,0].plot(node_count_history, label='Bounded', alpha=0.7)  # placeholder - real data from runs
    axs[0,0].plot(node_count_history, label='Open (Infinite)', alpha=0.9)  
    axs[0,0].set_title('Node Count Growth')
    axs[0,0].legend()

    # Collapse Events
    axs[0,1].bar(['Bounded', 'Open'], [bounded['collapse_events'], open_mode['collapse_events']])
    axs[0,1].set_title('Collapse Events')

    # Final Node Count
    axs[0,2].bar(['Bounded', 'Open'], [bounded['final_nodes'], open_mode['final_nodes']])
    axs[0,2].set_title('Final Node Count')

    # Logical Error Rate (Toric)
    axs[1,0].bar(['Bounded', 'Open'], 
                 [bounded['avg_logical_error_rate'], open_mode['avg_logical_error_rate']])
    axs[1,0].set_title('Avg Logical Error Rate')

    # Fission Events
    axs[1,1].bar(['Bounded', 'Open'], [bounded['total_fissions'], open_mode['total_fissions']])
    axs[1,1].set_title('Total Fission Events')

    # Anyon Count
    axs[1,2].bar(['Bounded', 'Open'], 
                 [bounded['avg_anyon_count'], open_mode['avg_anyon_count']])
    axs[1,2].set_title('Average Anyon Count')

    plt.suptitle("Tordial-GS Stress Sweep: Infinite Loophole + Toric-Code Metrics")
    plt.tight_layout()
    plt.savefig("stress_sweep_full_comparison.png")
    plt.show()

    # Save results
    with open("stress_results_full.json", "w") as f:
        json.dump({"bounded": bounded, "open": open_mode}, f, indent=2)

    print("\n✅ Full comparison complete!")
    print("   • Plots saved → stress_sweep_full_comparison.png")
    print("   • Data saved  → stress_results_full.json")


if __name__ == "__main__":
    compare_all()