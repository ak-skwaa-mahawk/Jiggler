import numpy as np
import matplotlib.pyplot as plt
import json
import time
import os
from tordial_gs_v13 import DualRingTordialMatrix, OpenTordialAgentNode

def run_stress_test(node_count=24, cycles=300, mode="open"):
    """Run stress test in bounded vs open (infinite) mode."""
    print(f"\n=== Stress Sweep: {mode.upper()} MODE | Nodes={node_count} | Cycles={cycles} ===")
    
    matrix = DualRingTordialMatrix(node_count=node_count, agent_mode=True)
    
    pressures = np.random.uniform(0.4, 1.2, cycles)
    resonances = np.random.uniform(0.2, 0.9, cycles)
    
    collapse_events = 0
    fission_events = 0
    sigma_history = []
    node_count_history = []
    
    start_time = time.time()
    
    for c in range(cycles):
        # Simulate varying load
        load = 1.0 + 0.5 * np.sin(c / 20)
        matrix.execute_heavy_load_cycle(system_load=load)
        
        current_nodes = len(matrix.nodes_a)
        node_count_history.append(current_nodes)
        
        # Get average sigma_T
        sigmas = [getattr(n, 'sigma_T', 0) for n in matrix.nodes_a if hasattr(n, 'sigma_T')]
        avg_sigma = np.mean(sigmas) if sigmas else 0
        sigma_history.append(avg_sigma)
        
        if avg_sigma < -800:
            collapse_events += 1
        
        # Count total fissions
        fission_events += sum(getattr(n, 'fission_count', 0) for n in matrix.nodes_a)
        
        if c % 50 == 0:
            print(f"Cycle {c:4d} | Nodes: {current_nodes:4d} | Avg σ_T: {avg_sigma:8.2f}")
    
    duration = time.time() - start_time
    
    results = {
        "mode": mode,
        "final_nodes": len(matrix.nodes_a),
        "collapse_events": collapse_events,
        "total_fissions": fission_events,
        "avg_sigma": float(np.mean(sigma_history)),
        "max_nodes": max(node_count_history),
        "duration_sec": round(duration, 2)
    }
    
    print(f"→ Final Nodes: {results['final_nodes']} | Collapses: {collapse_events} | Fissions: {fission_events}")
    return results


def compare_before_after():
    """Compare bounded vs infinite loophole performance."""
    print("Running Bounded vs Open comparison...\n")
    
    bounded = run_stress_test(mode="bounded")
    open_mode = run_stress_test(mode="open")
    
    # Plot comparison
    fig, axs = plt.subplots(2, 2, figsize=(14, 10))
    
    # Node growth
    axs[0,0].plot(range(len(bounded.get('node_history', []) or [])), label='Bounded')
    axs[0,0].plot(range(len(open_mode.get('node_history', []) or [])), label='Open (Infinite)')
    axs[0,0].set_title('Node Count Growth')
    axs[0,0].legend()
    
    axs[0,1].bar(['Bounded', 'Open'], [bounded['collapse_events'], open_mode['collapse_events']])
    axs[0,1].set_title('Collapse Events')
    
    axs[1,0].bar(['Bounded', 'Open'], [bounded['final_nodes'], open_mode['final_nodes']])
    axs[1,0].set_title('Final Node Count')
    
    axs[1,1].bar(['Bounded', 'Open'], [bounded['total_fissions'], open_mode['total_fissions']])
    axs[1,1].set_title('Fission Events')
    
    plt.suptitle("Tordial-GS Stress Sweep: Bounded vs Infinite Loophole")
    plt.tight_layout()
    plt.savefig("stress_sweep_comparison.png")
    plt.show()
    
    with open("stress_results.json", "w") as f:
        json.dump({"bounded": bounded, "open": open_mode}, f, indent=2)
    
    print("\nComparison complete. Results saved to stress_results.json + stress_sweep_comparison.png")


if __name__ == "__main__":
    compare_before_after()