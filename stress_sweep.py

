import numpy as np
import matplotlib.pyplot as plt
import json
import time
from tordial_gs_v13 import DualRingTordialMatrix

def run_stress_test(node_count=20, cycles=400, mode="open"):
    """Stress test with spawning rate and global energy tracking."""
    print(f"\n=== Stress Sweep: {mode.upper()} MODE | Initial Nodes={node_count} | Cycles={cycles} ===")

    matrix = DualRingTordialMatrix(node_count=node_count, agent_mode=True)

    collapse_events = 0
    fission_events = 0
    spawn_events = 0                    # New: Track dynamic spawning
    sigma_history = []
    node_count_history = []
    logical_error_history = []
    anyon_count_history = []
    corrections_history = []
    energy_history = []                 # New: Global energy tracking

    start_time = time.time()

    for c in range(cycles):
        load = 1.0 + 0.5 * np.sin(c / 20.0)
        matrix.execute_heavy_load_cycle(system_load=load)

        current_nodes = len(matrix.nodes_a)
        node_count_history.append(current_nodes)

        # Sigma_T
        sigmas = [getattr(n, 'sigma_T', 0.0) for n in matrix.nodes_a if hasattr(n, 'sigma_T')]
        avg_sigma = np.mean(sigmas) if sigmas else 0.0
        sigma_history.append(avg_sigma)

        if avg_sigma < -800:
            collapse_events += 1

        # Fission + Spawn tracking
        fission_events += sum(getattr(n, 'fission_count', 0) for n in matrix.nodes_a)
        
        # Global energy
        current_energy = getattr(matrix, 'global_energy', 0.0)
        energy_history.append(current_energy)

        # Surface Code metrics
        ler = getattr(matrix, 'logical_error_rate', 0.0)
        logical_error_history.append(ler)
        anyon_count = len(getattr(matrix, 'anyons', []))
        anyon_count_history.append(anyon_count)
        corrections = getattr(matrix, 'corrections_made', 0)
        corrections_history.append(corrections)

        if c % 60 == 0:
            print(f"Cycle {c:4d} | Nodes: {current_nodes:4d} | "
                  f"Energy: {current_energy:7.1f} | LER: {ler:.4f} | "
                  f"Corrections: {corrections}")

    duration = time.time() - start_time

    # Calculate spawning rate (derivative of node count)
    spawn_rate = np.diff(node_count_history).mean() if len(node_count_history) > 1 else 0.0

    results = {
        "mode": mode,
        "final_nodes": current_nodes,
        "collapse_events": collapse_events,
        "total_fissions": fission_events,
        "total_spawns_estimated": int(sum(np.maximum(np.diff(node_count_history), 0))),
        "avg_spawn_rate_per_cycle": float(spawn_rate),
        "avg_sigma": float(np.mean(sigma_history)),
        "avg_logical_error_rate": float(np.mean(logical_error_history)),
        "avg_corrections_per_cycle": float(np.mean(corrections_history)),
        "avg_anyon_count": float(np.mean(anyon_count_history)),
        "final_global_energy": float(current_energy),
        "avg_global_energy": float(np.mean(energy_history)),
        "duration_sec": round(duration, 2)
    }

    print(f"→ Final Nodes: {results['final_nodes']} | Avg Spawn Rate: {results['avg_spawn_rate_per_cycle']:.3f}/cycle | "
          f"Final Energy: {results['final_global_energy']:.1f}")
    return results


def compare_infinite_loophole():
    """Compare bounded vs dynamic spawning (Infinite Architecture)"""
    print("Running Full Infinite Loophole Comparison...\n")

    bounded = run_stress_test(mode="bounded")
    open_mode = run_stress_test(mode="open")

    fig, axs = plt.subplots(2, 3, figsize=(18, 11))

    # Node growth
    axs[0,0].set_title("Node Count Growth")
    axs[0,0].plot(range(len(bounded.get('node_count_history', [0]))), label='Bounded', alpha=0.7)
    axs[0,0].plot(range(len(open_mode.get('node_count_history', [0]))), label='Open (Dynamic Spawning)', alpha=0.9)
    axs[0,0].legend()

    # Global Energy
    axs[0,1].set_title("Global Energy Evolution")
    axs[0,1].plot(energy_history, label='Bounded', alpha=0.7)   # placeholder
    axs[0,1].plot(energy_history, label='Open', alpha=0.9)
    axs[0,1].legend()

    axs[0,2].set_title("Avg Spawn Rate per Cycle")
    axs[0,2].bar(['Bounded', 'Open'], [bounded['avg_spawn_rate_per_cycle'], open_mode['avg_spawn_rate_per_cycle']])

    axs[1,0].set_title("Final Node Count")
    axs[1,0].bar(['Bounded', 'Open'], [bounded['final_nodes'], open_mode['final_nodes']])

    axs[1,1].set_title("Avg Logical Error Rate")
    axs[1,1].bar(['Bounded', 'Open'], [bounded['avg_logical_error_rate'], open_mode['avg_logical_error_rate']])

    axs[1,2].set_title("Avg Global Energy")
    axs[1,2].bar(['Bounded', 'Open'], [bounded['avg_global_energy'], open_mode['avg_global_energy']])

    plt.suptitle("Tordial-GS v13: Infinite Loophole Architecture Evaluation\n"
                 "(κ-Driven Spawning + Global Energy Pressure)")
    plt.tight_layout()
    plt.savefig("stress_sweep_infinite_loophole.png")
    plt.show()

    with open("stress_results_infinite.json", "w") as f:
        json.dump({"bounded": bounded, "open": open_mode}, f, indent=2)

    print("\n✅ Infinite Loophole comparison complete!")
    print("   • Plot saved → stress_sweep_infinite_loophole.png")


if __name__ == "__main__":
    compare_infinite_loophole()