class GSSweep:
    def __init__(self):
        self.phi_op = t["phi_op"]
        self.gear = t["gear_shift_correction"]

    def compute_gs(self, d: int, r: int) -> Dict:
        denom = 4 * self.phi_op * self.gear
        sigma = r - (d ** 2) / denom
        if sigma <= 0:
            return {"d": d, "r": r, "sigma_T": 0.0, "kappa_GS_T": 0.0, "band": "SUBCRITICAL"}
        kappa = sigma / d
        band = "GOLDILOCKS" if (5.0 <= kappa <= 8.5 and sigma >= 95) else \
               "DEEP_GS" if kappa > 8.5 else "MARGINAL" if kappa >= 3.2 else "SUBCRITICAL"
        return {"d": d, "r": r, "sigma_T": round(sigma, 4), "kappa_GS_T": round(kappa, 4), "band": band}


class TordialNode:
    def __init__(self, d: int, r: int):
        self.OMEGA_RADS = 2 * math.pi * t["base_frequency_hz"]
        self.TAU_3D = 2 * t["pi_3d"]
        self.CHASE_RATIO_TAU = self.TAU_3D / t["phi_op"]
        self.d = d
        self.r = r
        self.load = 0.0  # Current computational load

    def run_step(self, t_seconds: float, external_load: float = 1.0) -> Dict:
        phase = (self.OMEGA_RADS * t_seconds) % self.TAU_3D
        coupling = GSSweep().compute_gs(self.d, self.r)
        self.load = external_load
        return {
            "raw_phase_rads": phase,
            "chase_lock_status": "LOCKED" if phase < self.CHASE_RATIO_TAU else "DRIFTING",
            "coupling_telemetry": coupling,
            "load": external_load
        }


# ====================== HEAVY LOAD DUAL-RING MATRIX ======================
class DualRingTordialMatrix:
    def __init__(self, node_count: int = 12):
        self.node_count = node_count
        self.BASE_FREQUENCY_HZ = t["base_frequency_hz"]
        self.MIN_FREQUENCY_FLOOR_HZ = config["governance"]["min_frequency_floor_hz"]
        self.current_filtered_frequency_hz = self.BASE_FREQUENCY_HZ
        self.current_tick = 0
        self.t_start = time.time()
        self.active_ring = "RING_A"

        self.ledger = TordialSQLiteLedger()
        self.gs_sweep = GSSweep()

        self._seed_nodes()
        self.quarantined_a: Set[int] = set()
        self.quarantined_b: Set[int] = set()
        self.consec_drift = {"A": {i: 0 for i in range(node_count)}, "B": {i: 0 for i in range(node_count)}}

    def _seed_nodes(self):
        df = self.gs_sweep.run_sweep()
        preferred = pd.concat([
            df[df["band"] == "GOLDILOCKS"].sample(n=self.node_count//2, replace=True),
            df[df["band"].isin(["DEEP_GS", "MARGINAL"])].sample(n=self.node_count - self.node_count//2, replace=True)
        ])
        self.nodes_a = [TordialNode(int(row["d"]), int(row["r"])) for _, row in preferred.iterrows()]
        self.nodes_b = [TordialNode(int(row["d"]), int(row["r"])) for _, row in preferred.iterrows()]
        self.node_bands = list(preferred["band"])

    def execute_heavy_load_cycle(self, system_load: float = 1.0):
        """Heavy load aware governance with load shedding + backpressure"""
        self.current_tick += 1
        t_now = time.time() - self.t_start

        # Apply load pressure
        load_factor = min(3.0, system_load)

        snapshots_a = []
        for i in range(self.node_count):
            load = load_factor * (1.2 if i in self.quarantined_a else 1.0)
            rep = self.nodes_a[i].run_step(t_now, load)
            if i in self.quarantined_a:
                rep["chase_lock_status"] = "QUARANTINED"
            snapshots_a.append({"node_index": i, "telemetry": rep})

        snapshots_b = [dict(s) for s in snapshots_a]  # mirror for now

        self._evaluate_health(snapshots_a, self.quarantined_a, "A")
        self._evaluate_health(snapshots_b, self.quarantined_b, "B")

        # === FAILOVER + LOAD SHEDDING ===
        active_a = self.node_count - len(self.quarantined_a)
        if self.active_ring == "RING_A" and active_a < self.node_count // 2:
            self.active_ring = "RING_B"
            print(f"[🚨 HEAVY LOAD FAILOVER] RING_A → RING_B at tick {self.current_tick}")

        # Backpressure & Load Shedding
        targeted = snapshots_a if self.active_ring == "RING_A" else snapshots_b
        high_load_nodes = sum(1 for s in targeted if s["telemetry"]["load"] > 2.2)

        if high_load_nodes > self.node_count * 0.4:
            print(f"[⚠️ BACKPRESSURE] Shedding {high_load_nodes} high-load nodes")
            # In real system: reduce input rate or activate shedding policy

        # GS-aware frequency
        drifting = sum(1 for s in targeted if s["telemetry"]["chase_lock_status"] == "DRIFTING")
        active = self.node_count - len(self.quarantined_a if self.active_ring == "RING_A" else self.quarantined_b)
        avg_kappa = np.mean([s["telemetry"]["coupling_telemetry"].get("kappa_GS_T", 0) 
                           for s in targeted]) or 0.0

        strength = min(1.0, 0.52 + avg_kappa * 0.65)
        target = self.BASE_FREQUENCY_HZ if drifting == 0 else \
                 self.BASE_FREQUENCY_HZ - (self.BASE_FREQUENCY_HZ - self.MIN_FREQUENCY_FLOOR_HZ) * \
                 (drifting / active if active > 0 else 1) * (1 - strength)

        self.current_filtered_frequency_hz = max(45.0, min(95.0, target))

    def _evaluate_health(self, snapshots, quarantined, ring):
        for entry in snapshots:
            idx = entry["node_index"]
            if idx in quarantined: continue
            status = entry["telemetry"]["chase_lock_status"]
            kappa = entry["telemetry"]["coupling_telemetry"].get("kappa_GS_T", 0)

            if status == "DRIFTING":
                penalty = 0.45 if kappa > 6.0 else 1.0
                self.consec_drift[ring][idx] += penalty
                if self.consec_drift[ring][idx] >= 5.0:
                    quarantined.add(idx)
            else:
                self.consec_drift[ring][idx] = max(0, self.consec_drift[ring][idx] - 1.5)


