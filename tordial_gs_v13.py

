class Anyon:
    def __init__(self, anyon_type: str, node_id: int, position: float):
        self.type = anyon_type  # 'e' (Z-error), 'm' (X-error), 'f'
        self.node_id = node_id
        self.position = position
        self.lifetime = 0


class SurfaceCodeDecoder:
    """Simple greedy decoder for surface code syndromes (MWPM approximation)"""
    def decode(self, syndromes: List[Tuple[int, str]]) -> List[Tuple[int, int]]:
        """Return list of correction edges (node_id pairs)"""
        corrections = []
        unpaired = syndromes[:]
        i = 0
        while i < len(unpaired):
            for j in range(i+1, len(unpaired)):
                if unpaired[i][1] == unpaired[j][1]:  # same anyon type
                    corrections.append((unpaired[i][0], unpaired[j][0]))
                    unpaired.pop(j)
                    unpaired.pop(i)
                    break
            else:
                i += 1
        return corrections


