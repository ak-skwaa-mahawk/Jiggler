# ====================== GLOBAL CURVATURE FIELD ======================
class CurvatureField:
    """
    Global curvature field C(t) driven by:
      - avg sigma_T
      - avg kappa
      - global energy
      - logical error rate
    Produces:
      - curvature_pressure in [0, 1.2]
      - resonance in [0, 1.0]
    """
    def __init__(self):
        self.last_pressure = 0.0
        self.last_resonance = 0.0

    def compute(
        self,
        avg_sigma: float,
        avg_kappa: float,
        global_energy: float,
        logical_error_rate: float,
        node_count: int,
    ) -> tuple[float, float]:
        kappa_norm = max(0.0, min(1.0, avg_kappa / 12.0))
        energy_norm = max(0.0, min(1.0, global_energy / 3000.0))
        sigma_norm = max(-1.0, min(1.0, avg_sigma / 500.0))
        ler = max(0.0, min(1.0, logical_error_rate))

        base_pressure = 0.45 * kappa_norm + 0.35 * energy_norm + 0.20 * max(0.0, sigma_norm)
        pressure = base_pressure * (1.0 - 0.6 * ler)
        crowding = max(0.0, min(0.3, (node_count - 24) / 80.0))
        pressure += crowding

        resonance = (0.55 * kappa_norm + 0.35 * max(0.0, sigma_norm) + 0.10 * energy_norm)
        resonance *= (1.0 - 0.8 * ler)

        pressure = max(0.0, min(1.2, pressure))
        resonance = max(0.0, min(1.0, resonance))

        alpha = 0.35
        pressure = alpha * pressure + (1 - alpha) * self.last_pressure
        resonance = alpha * resonance + (1 - alpha) * self.last_resonance

        self.last_pressure = pressure
        self.last_resonance = resonance
        return pressure, resonance


# ====================== GS SWEEP ======================
class GSSweep:
    def __init__(self):
        self.PHI_OP = 1.65036
        self.GEAR_SHIFT = 1.04

    def compute_gs(self, d: int, r: int) -> Dict:
        denom = 4 * self.PHI_OP * self.GEAR_SHIFT
        sigma_T = r - (d ** 2) / denom
        if sigma_T <= 0:
            return {"d": d, "r": r, "sigma_T": 0.0, "kappa_GS_T": 0.0, "rho_GS_T": 0.0, "band": "SUBCRITICAL"}
        kappa = sigma_T / d
        rho = math.sqrt(sigma_T) / d
        return {"d": d, "r": r, "sigma_T": round(sigma_T, 4), "kappa_GS_T": round(kappa, 4), "rho_GS_T": round(rho, 4), "band": "GOLDILOCKS" if kappa >= 5.0 else "SUBCRITICAL"}


# ====================== CORE NODE ======================
class TordialNode:
    def __init__(self, d: int, r: int):
        self.OMEGA_RADS = 2 * math.pi * 79.0
        self.TAU_3D = 2 * 3.20442315
        self.CHASE_RATIO_TAU = self.TAU_3D / 1.65036
        self.d = d
        self.r = r

    def run_step(self, t_seconds: float) -> Dict:
        phase = (self.OMEGA_RADS * t_seconds) % self.TAU_3D
        return {"raw_phase_rads": phase, "chase_lock_status": "LOCKED" if phase < self.CHASE_RATIO_TAU else "DRIFTING", "coupling_telemetry": GSSweep().compute_gs(self.d, self.r)}


# ====================== MAIN MANIFOLD ======================
class DualRingTordialMatrix:
    def __init__(self, node_count: int = 8, db_path="tordial_gs.db"):
        self.node_count = node_count
        self.BASE_FREQUENCY_HZ = 79.0
        self.current_filtered_frequency_hz = 79.0
