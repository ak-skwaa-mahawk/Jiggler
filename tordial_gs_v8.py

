                rollback_trigger = 1

        summary = {
            "timestamp": datetime.now().isoformat(), "node_count": self.node_count, "final_freq": self.current_filtered_frequency_hz,
            "quarantine_rate": float(pressure), "avg_kappa": avg_kappa, "stability_score": float(resonance) if rollback_trigger == 0 else 0.0,
            "runtime_env": "Python_TordialGS_v8_Active", "holonomy_norm": current_h, "holonomy_norm_local": current_h * 0.41,
            "commutator_1_5": c15, "commutator_2_5": c25, "rollback_flag": rollback_trigger
        }
        self.ledger.log_run(summary)


# ====================== SQLITE LEDGER LAYER ======================
class TordialSQLiteLedger:
    def __init__(self, db_path="tordial_gs.db"):
        self.conn = sqlite3.connect(db_path)
        self.conn.execute("""
            CREATE TABLE IF NOT EXISTS runs (
                id INTEGER PRIMARY KEY, timestamp TEXT, node_count INTEGER, final_freq REAL, quarantine_rate REAL, avg_kappa REAL, stability_score REAL,
                runtime_env TEXT DEFAULT 'Python_TordialGS_v8', holonomy_norm REAL DEFAULT 0.0, holonomy_norm_local REAL DEFAULT 0.0,
                commutator_1_5 REAL DEFAULT 0.0, commutator_2_5 REAL DEFAULT 0.0, rollback_flag INTEGER DEFAULT 0
            )
        """)
        self.conn.commit()

    def fetch_latest_holonomy(self) -> float:
        try:
            cursor = self.conn.cursor()
            cursor.execute("SELECT holonomy_norm FROM runs ORDER BY id DESC LIMIT 1;")
            row = cursor.fetchone()
            return row[0] if row else 0.0
        except:
            return 0.0

    def log_run(self, d: Dict):
        self.conn.execute("""
            INSERT INTO runs (timestamp, node_count, final_freq, quarantine_rate, avg_kappa, stability_score, runtime_env, holonomy_norm, holonomy_norm_local, commutator_1_5, commutator_2_5, rollback_flag)
            VALUES (?,?,?,?,?,?,?,?,?,?,?,?)
        """, (d["timestamp"], d["node_count"], d["final_freq"], d["quarantine_rate"], d["avg_kappa"], d["stability_score"], d["runtime_env"], d["holonomy_norm"], d["holonomy_norm_local"], d["commutator_1_5"], d["commutator_2_5"], d["rollback_flag"]))
        self.conn.commit()
        print("✅ [LEDGER SYNC] Swarm parameters cleanly committed to unified database.")


