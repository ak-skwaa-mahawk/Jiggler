            t_now = time.time() - self.t_start
            self.current_snapshots = [{"node_index": i, "telemetry": self.nodes_a[i].run_step(t_now)} for i in range(self.node_count)]
            time.sleep(0.001)

        # Extract underlying metrics to feed into the newly added Curvature Controller
        avg_sigma = np.mean([s["telemetry"]["coupling_telemetry"]["sigma_T"] for s in self.current_snapshots]) or 250.0
        avg_kappa = np.mean([s["telemetry"]["coupling_telemetry"]["kappa_GS_T"] for s in self.current_snapshots]) or 8.8
        
        # Drive field parameters
        simulated_energy = 1450.0 + (avg_kappa * 50)
        simulated_ler = 0.02 # Nominal logical error rate target
        
        # Execute the Curvature Controller step
        pressure, resonance = self.c_field.compute(avg_sigma, avg_kappa, simulated_energy, simulated_ler, self.node_count)
        print(f"🌀 [FIELD CONTROLLER] Evaluated Curvature Pressure: {pressure:.4f} | Resonance Stability: {resonance:.4f}")

        # Compute dynamic path-dependent algebraic drift vectors
        phase_a = np.mean([s["telemetry"]["raw_phase_rads"] for s in self.current_snapshots]) or 0.1
        phase_b = self.current_filtered_frequency_hz / 79.0
        
        c15 = -0.010835 * math.sin(phase_a) * (self.node_count / 10.0) * pressure
        c25 = -0.010835 * math.cos(phase_b) * (self.node_count / 10.0) * resonance
        current_h = math.sqrt(c15**2 + c25**2) * 7.07

