# ====================== CORE CLASSES (v4 refined) ======================
class TordialNode:
    def __init__(self, d: int = 42, r: int = 380):
        self.PI_3D = 3.20442315
        self.TAU_3D = 2 * self.PI_3D
        self.PHI_OP = 1.65036
        self.GEAR_SHIFT_CORRECTION = 1.04
        self.OMEGA_FREQ_HZ = 79.0
        self.OMEGA_RADS = 2 * math.pi * self.OMEGA_FREQ_HZ
        self.CHASE_RATIO_TAU = self.TAU_3D / self.PHI_OP
        self.DRIFT_BUDGET_D = self.GEAR_SHIFT_CORRECTION - 1.0
        self.d = d
        self.r = r

    def get_gs_constants(self) -> Dict[str, float] | None:
        denom = 4 * self.PHI_OP * self.GEAR_SHIFT_CORRECTION
        sigma_T = self.r - (self.d ** 2) / denom
        if sigma_T <= 0:
            return None
        kappa = sigma_T / self.d
        lam = math.sqrt(sigma_T)
        rho = lam / self.d
        return {"sigma_T": sigma_T, "kappa_GS_T": kappa,
                "lambda_GS_T": lam, "rho_GS_T": rho, "d": self.d, "r": self.r}

    def run_79hz_telemetry_step(self, t_seconds: float, accumulation_drift: float) -> Dict:
        phase = (self.OMEGA_RADS * t_seconds) % self.TAU_3D
        coupling = self.get_gs_constants()
        local_budget = self.DRIFT_BUDGET_D
        if coupling:
            rho_clamped = min(coupling["rho_GS_T"], 2.0)
            local_budget *= (1.0 + rho_clamped * 0.8)
        return {
            "raw_phase_rads": phase,
            "chase_lock_status": "LOCKED" if phase < self.CHASE_RATIO_TAU else "DRIFTING",
            "coupling_telemetry": coupling,
        }


# ====================== TOROIDAL EMBEDDING ======================
def toroidal_coordinates(phase: float, major_r: float = 3.0, minor_r: float = 1.0, node_id: int = 0):
    """Real 3D toroidal embedding."""
    theta = phase
    phi = (node_id * 0.7) % (2 * math.pi)  # spread nodes
    x = (major_r + minor_r * math.cos(phi)) * math.cos(theta)
    y = (major_r + minor_r * math.cos(phi)) * math.sin(theta)
    z = minor_r * math.sin(phi)
    return x, y, z


# ====================== PERSISTENT LEDGER ======================
class TordialSQLiteLedger:
    def __init__(self, db_path="tordial_gs.db"):
        self.conn = sqlite3.connect(db_path)
        self._init_db()

    def _init_db(self):
        self.conn.execute("""
            CREATE TABLE IF NOT EXISTS runs (
                id INTEGER PRIMARY KEY,
                timestamp TEXT,
                node_count INTEGER,
                base_d INTEGER,
                base_r INTEGER,
                final_freq REAL,
                avg_kappa REAL,
                max_kappa REAL,
                quarantine_rate REAL,
                stability_score REAL
            )
        """)
        self.conn.execute("""
            CREATE TABLE IF NOT EXISTS sweep_results (
                id INTEGER PRIMARY KEY,
                d INTEGER,
                r INTEGER,
                sigma_T REAL,
                kappa_GS_T REAL,
                stability_score REAL,
                notes TEXT
            )
        """)
        self.conn.commit()

    def log_run(self, data: Dict):
        self.conn.execute("""
            INSERT INTO runs 
            (timestamp, node_count, base_d, base_r, final_freq, avg_kappa, max_kappa, quarantine_rate, stability_score)
            VALUES (datetime('now'), ?, ?, ?, ?, ?, ?, ?, ?)
        """, (data['node_count'], data['base_d'], data['base_r'], data['final_freq'],
              data['avg_kappa'], data['max_kappa'], data['quarantine_rate'], data['stability_score']))
        self.conn.commit()

    def log_sweep(self, d: int, r: int, sigma: float, kappa: float, score: float, notes: str = ""):
        self.conn.execute("INSERT INTO sweep_results (d, r, sigma_T, kappa_GS_T, stability_score, notes) VALUES (?,?,?,?,?,?)",
                         (d, r, sigma, kappa, score, notes))
        self.conn.commit()


# ====================== GS SWEEP HARNESS ======================
class GSSweepHarness:
    def __init__(self, ledger: TordialSQLiteLedger):
        self.ledger = ledger

    def run_sweep(self, d_range=(25, 65, 5), r_range=(200, 520, 40)):
        print("[+] Starting GS parameter sweep...")
        results = []
        d_values = range(*d_range)
        r_values = range(*r_range)

        for d in d_values:
            row = []
            for r in r_values:
                # Quick stability test
                node = TordialNode(d, r)
                coupling = node.get_gs_constants()
                if not coupling:
                    score = 0.0
                else:
                    # Stability heuristic
                    score = min(1.0, coupling["kappa_GS_T"] / 8.0) * (1.0 if coupling["sigma_T"] > 50 else 0.6)
                self.ledger.log_sweep(d, r, coupling["sigma_T"] if coupling else 0,
                                    coupling["kappa_GS_T"] if coupling else 0, score)
                row.append(score)
                print(f"  d={d:2d} r={r:3d} → κ={coupling['kappa_GS_T']:.2f} score={score:.3f}" if coupling else f"  d={d:2d} r={r:3d} → unstable")
            results.append(row)

        self.plot_heatmap(results, list(d_values), list(r_values))
        return results

    def plot_heatmap(self, data: List[List[float]], d_vals, r_vals):
        plt.figure(figsize=(10, 7))
        im = plt.imshow(data, cmap='viridis', origin='lower')
        plt.colorbar(im, label='Stability Score')
        plt.xticks(range(len(r_vals)), r_vals, rotation=45)
        plt.yticks(range(len(d_vals)), d_vals)
        plt.xlabel('r (relations)')
        plt.ylabel('d (generators)')
        plt.title('Tordial-GS Stability Heatmap\n(Higher = More Stable Infinite-Density Regime)')
        plt.tight_layout()
        plt.savefig('tordial_gs_stability_heatmap.png', dpi=200)
        plt.show()


# ====================== LIVE TOROIDAL VISUALIZATION ======================
class TordialLiveVisualizer:
    def __init__(self, matrix):
        self.matrix = matrix
        self.fig = plt.figure(figsize=(12, 8))
        self.ax = self.fig.add_subplot(111, projection='3d')
        self.scat = None
        self.anim = None

    def update_plot(self, frame):
        self.ax.clear()
        self.ax.set_xlim(-5, 5)
        self.ax.set_ylim(-5, 5)
        self.ax.set_zlim(-2, 2)
        self.ax.set_title(f"Tordial-GS Live Manifold | Tick {self.matrix.current_tick} | Freq {self.matrix.current_filtered_frequency_hz:.1f} Hz")

        snapshots = self.matrix.get_current_snapshots()  # you'll add this helper
        colors = []
        sizes = []

        for i, snap in enumerate(snapshots):
            phase = snap["telemetry"]["raw_phase_rads"]
            x, y, z = toroidal_coordinates(phase, node_id=i)
            self.ax.scatter([x], [y], [z], c='blue' if snap["telemetry"]["chase_lock_status"] == "LOCKED" else 'red',
                           s=80, alpha=0.9)
            colors.append('blue' if snap["telemetry"]["chase_lock_status"] == "LOCKED" else 'red')

        return self.scat,

    def start(self):
        self.anim = FuncAnimation(self.fig, self.update_plot, interval=400, blit=False)
        plt.show()


