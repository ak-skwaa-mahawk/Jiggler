# ====================== POST-RUN ANALYSIS ======================
def run_post_analysis(db_path="tordial_gs.db"):
    conn = sqlite3.connect(db_path)
    df = pd.read_sql_query("SELECT * FROM runs ORDER BY timestamp DESC", conn)
    sweep = pd.read_sql_query("SELECT * FROM sweep_results", conn)

    print(f"\n=== Tordial-GS Post-Run Analysis ===\n")
    print(df.describe())

    # Goldilocks Classification
    sweep["zone"] = pd.cut(sweep["kappa_GS_T"], 
                          bins=[0, 3.5, 7.5, 20], 
                          labels=["Low-κ (Unstable)", "Goldilocks", "High-κ (Overpowered)"])

    print("\nGoldilocks GS Zones:")
    print(sweep["zone"].value_counts())

    # Visuals
    plt.figure(figsize=(12, 5))
    sns.scatterplot(data=sweep, x="d", y="r", hue="kappa_GS_T", size="stability_score", palette="viridis")
    plt.title("GS Parameter Space — Goldilocks Zones")
    plt.savefig("gs_goldilocks_scatter.png", dpi=200)
    plt.show()

    # Heatmap again
    pivot = sweep.pivot_table(values="stability_score", index="d", columns="r")
    plt.figure(figsize=(10, 6))
    sns.heatmap(pivot, annot=False, cmap="magma")
    plt.title("Tordial-GS Stability Heatmap")
    plt.savefig("gs_stability_heatmap.png", dpi=200)
    plt.show()


# ====================== GOLDILOCKS CLASSIFIER ======================
def classify_goldilocks_zone(kappa: float, sigma: float) -> str:
    if 4.2 <= kappa <= 7.8 and sigma > 80:
        return "GOLDILOCKS — Optimal Infinite-Density Regime"
    elif kappa < 3.5:
        return "LOW — Risk of collapse"
    else:
        return "HIGH — Strong but potentially wasteful"


