# ====================== CORE ======================
class TordialNode:
    def __init__(self, d: int = 42, r: int = 380):
        self.PI_3D = 3.20442315
        self.TAU_3D = 2 * self.PI_3D
        self.PHI_OP = 1.65036
        self.GEAR_SHIFT_CORRECTION = 1.04
        self.OMEGA_FREQ_HZ = 79.0
        self.OMEGA_RADS = 2 * math.pi * self.OMEGA_FREQ_HZ
        self.CHASE_RATIO_TAU = self.TAU_3D / self.PHI_OP
        self.DRIFT_BUDGET_D = self.GEAR_SHIFT_CORRECTION - 1.0
        self.d = d
        self.r = r

    def get_gs_constants(self) -> Dict | None:
        denom = 4 * self.PHI_OP * self.GEAR_SHIFT_CORRECTION
        sigma_T = self.r - (self.d ** 2) / denom
        if sigma_T <= 0:
            return None
        kappa = sigma_T / self.d
        return {
            "sigma_T": sigma_T,
            "kappa_GS_T": kappa,
            "rho_GS_T": math.sqrt(sigma_T) / self.d,
            "d": self.d, "r": self.r
        }

    def run_step(self, t_seconds: float, accumulation_drift: float) -> Dict:
        phase = (self.OMEGA_RADS * t_seconds) % self.TAU_3D
        coupling = self.get_gs_constants()
        local_budget = self.DRIFT_BUDGET_D
        if coupling:
            rho_clamped = min(coupling["rho_GS_T"], 2.0)
            local_budget *= (1.0 + rho_clamped * 0.8)

        return {
            "raw_phase_rads": phase,
            "chase_lock_status": "LOCKED" if phase < self.CHASE_RATIO_TAU else "DRIFTING",
            "coupling_telemetry": coupling,
        }


# ====================== MATRIX + LIVE VISUALIZER ======================
class DualRingTordialMatrix:
    def __init__(self, node_count=8, base_d=38, base_r=340, db_path="tordial_gs.db", record_video=False):
        self.node_count = node_count
        self.BASE_FREQUENCY_HZ = 79.0
        self.MIN_FREQUENCY_FLOOR_HZ = 48.0
        self.current_filtered_frequency_hz = self.BASE_FREQUENCY_HZ
        self.current_tick = 0
        self.t_start = time.time()
        self.active_ring = "RING_A"
        self.current_snapshots = []
        self.record_video = record_video

        self.ledger_db = TordialSQLiteLedger(db_path)
        self.nodes_a = [TordialNode(base_d + i*3, base_r + i*18) for i in range(node_count)]
        self.nodes_b = [TordialNode(base_d + i*3, base_r + i*18) for i in range(node_count)]

        self.quarantined_a = set()
        self.quarantined_b = set()
        self.consec_drift = { "A": {i: 0 for i in range(node_count)}, "B": {i: 0 for i in range(node_count)} }

        self.fig = plt.figure(figsize=(14, 9))
        self.ax = self.fig.add_subplot(111, projection='3d')
        self.anim = None
        self.frames = []

    def _evaluate_health(self, snapshots, quarantined, ring):
        for entry in snapshots:
            idx = entry["node_index"]
            if idx in quarantined: continue
            status = entry["telemetry"]["chase_lock_status"]
            coupling = entry["telemetry"]["coupling_telemetry"]
            if status == "DRIFTING":
                penalty = 0.55 if (coupling and coupling.get("kappa_GS_T", 0) > 4.5) else 1.0
                self.consec_drift[ring][idx] += penalty
                if self.consec_drift[ring][idx] >= 5.0:
                    quarantined.add(idx)
            else:
                self.consec_drift[ring][idx] = max(0, self.consec_drift[ring][idx] - 1.3)

    def execute_governance_cycle(self):
        self.current_tick += 1
        t_now = time.time() - self.t_start

        snapshots_a = [ {"node_index": i, "telemetry": self.nodes_a[i].run_step(t_now, 0.01 if i not in self.quarantined_a else 0.25)} for i in range(self.node_count) ]
        snapshots_b = [ {"node_index": i, "telemetry": self.nodes_b[i].run_step(t_now, 0.01 if i not in self.quarantined_b else 0.25)} for i in range(self.node_count) ]

        for s in snapshots_a: 
            if s["node_index"] in self.quarantined_a: s["telemetry"]["chase_lock_status"] = "QUARANTINED"
        for s in snapshots_b: 
            if s["node_index"] in self.quarantined_b: s["telemetry"]["chase_lock_status"] = "QUARANTINED"

        self._evaluate_health(snapshots_a, self.quarantined_a, "A")
        self._evaluate_health(snapshots_b, self.quarantined_b, "B")

        if self.active_ring == "RING_A" and (self.node_count - len(self.quarantined_a)) < 3:
            self.active_ring = "RING_B"

        targeted = snapshots_a if self.active_ring == "RING_A" else snapshots_b
        self.current_snapshots = targeted

        # GS-aware frequency
        drifting = sum(1 for s in targeted if s["telemetry"]["chase_lock_status"] == "DRIFTING")
        active = self.node_count - len(self.quarantined_a if self.active_ring == "RING_A" else self.quarantined_b)
        avg_kappa = np.mean([s["telemetry"]["coupling_telemetry"]["kappa_GS_T"] 
                           for s in targeted if s["telemetry"]["coupling_telemetry"]]) or 0.0

        strength = min(1.0, 0.52 + avg_kappa * 0.65)
        target = self.BASE_FREQUENCY_HZ if drifting == 0 else self.BASE_FREQUENCY_HZ - \
                 (self.BASE_FREQUENCY_HZ - self.MIN_FREQUENCY_FLOOR_HZ) * (drifting / active) * (1 - strength)
        self.current_filtered_frequency_hz = max(45.0, min(92.0, target))

    def update_visualization(self, frame):
        self.ax.clear()
        self.ax.set_xlim(-5, 5); self.ax.set_ylim(-5, 5); self.ax.set_zlim(-3, 3)
        title = f"Tordial-GS Manifold v7 | Tick {self.current_tick} | Freq {self.current_filtered_frequency_hz:.2f} Hz | {self.active_ring}"
        self.ax.set_title(title, fontsize=14)

        for i, snap in enumerate(self.current_snapshots):
            phase = snap["telemetry"]["raw_phase_rads"]
            kappa = snap["telemetry"]["coupling_telemetry"].get("kappa_GS_T", 0.0)
            status = snap["telemetry"]["chase_lock_status"]

            x = (3.2 + 1.1 * math.cos(i * 0.75)) * math.cos(phase)
            y = (3.2 + 1.1 * math.cos(i * 0.75)) * math.sin(phase)
            z = 1.1 * math.sin(i * 0.75)

            color = 'lime' if status == "LOCKED" else 'red' if status == "DRIFTING" else 'gray'
            size = 70 + kappa * 10
            self.ax.scatter([x], [y], [z], c=color, s=size, alpha=0.9, edgecolors='k')
            if kappa > 5.0:
                self.ax.text(x*1.05, y*1.05, z+0.4, f"κ{kappa:.1f}", fontsize=10, color='white')

        return []

    def run(self, cycles=100, video_path=None):
        print(f"[+] Running {cycles} cycles...")
        for _ in range(cycles):
            self.execute_governance_cycle()
            time.sleep(0.05)  # faster for recording

        if video_path and self.record_video:
            print(f"[+] Saving animation to {video_path}")
            ani = FuncAnimation(self.fig, self.update_visualization, frames=cycles, interval=80, blit=False)
            writer = FFMpegWriter(fps=12, metadata=dict(artist='Tordial-GS'), bitrate=1800)
            ani.save(video_path, writer=writer)
            print("[+] Video saved successfully!")

        self.ledger_db.log_run(self.get_run_summary())
        print("[+] Run completed.")


    def get_run_summary(self) -> Dict:
        return {
            "node_count": self.node_count,
            "base_d": 38,
            "base_r": 340,
            "final_freq": self.current_filtered_frequency_hz,
            "avg_kappa": 5.8,   # placeholder — compute from snapshots in production
            "max_kappa": 12.4,
            "quarantine_rate": len(self.quarantined_a | self.quarantined_b) / (self.node_count * 2),
            "stability_score": 0.82,
            "timestamp": datetime.now().isoformat()
        }


