# ====================== CORE NODE ======================
class TordialNode:
    def __init__(self, d: int = 42, r: int = 380):
        self.PI_3D = 3.20442315
        self.TAU_3D = 2 * self.PI_3D
        self.PHI_OP = 1.65036
        self.GEAR_SHIFT_CORRECTION = 1.04
        self.OMEGA_FREQ_HZ = 79.0
        self.OMEGA_RADS = 2 * math.pi * self.OMEGA_FREQ_HZ
        self.CHASE_RATIO_TAU = self.TAU_3D / self.PHI_OP
        self.DRIFT_BUDGET_D = self.GEAR_SHIFT_CORRECTION - 1.0
        self.d = d
        self.r = r

    def get_gs_constants(self) -> Dict | None:
        denom = 4 * self.PHI_OP * self.GEAR_SHIFT_CORRECTION
        sigma_T = self.r - (self.d ** 2) / denom
        if sigma_T <= 0:
            return None
        kappa = sigma_T / self.d
        return {
            "sigma_T": sigma_T,
            "kappa_GS_T": kappa,
            "lambda_GS_T": math.sqrt(sigma_T),
            "rho_GS_T": math.sqrt(sigma_T) / self.d,
            "d": self.d, "r": self.r
        }

    def run_step(self, t_seconds: float, accumulation_drift: float) -> Dict:
        phase = (self.OMEGA_RADS * t_seconds) % self.TAU_3D
        coupling = self.get_gs_constants()
        local_budget = self.DRIFT_BUDGET_D
        if coupling:
            rho_clamped = min(coupling["rho_GS_T"], 2.0)
            local_budget *= (1.0 + rho_clamped * 0.8)

        return {
            "raw_phase_rads": phase,
            "chase_lock_status": "LOCKED" if phase < self.CHASE_RATIO_TAU else "DRIFTING",
            "coupling_telemetry": coupling,
            "local_drift_budget": local_budget
        }


# ====================== TOROIDAL VISUALIZER ======================
class TordialLiveVisualizer:
    def __init__(self, matrix):
        self.matrix = matrix
        self.fig = plt.figure(figsize=(13, 9))
        self.ax = self.fig.add_subplot(111, projection='3d')
        self.ax.set_xlabel('X'); self.ax.set_ylabel('Y'); self.ax.set_zlabel('Z')
        self.scat = None
        self.text = None

    def update(self, frame):
        self.ax.clear()
        self.ax.set_xlim(-5, 5)
        self.ax.set_ylim(-5, 5)
        self.ax.set_zlim(-2.5, 2.5)
        self.ax.set_title(f"Tordial-GS Live Manifold\n"
                         f"Tick {self.matrix.current_tick} | "
                         f"Freq {self.matrix.current_filtered_frequency_hz:.2f} Hz | "
                         f"Active Ring: {self.matrix.active_ring}")

        snapshots = self.matrix.current_snapshots
        for i, snap in enumerate(snapshots):
            phase = snap["telemetry"]["raw_phase_rads"]
            coupling = snap["telemetry"]["coupling_telemetry"]
            kappa = coupling["kappa_GS_T"] if coupling else 0.0

            x = (3.0 + 1.0 * math.cos(i * 0.8)) * math.cos(phase)
            y = (3.0 + 1.0 * math.cos(i * 0.8)) * math.sin(phase)
            z = 1.0 * math.sin(i * 0.8)

            color = 'lime' if snap["telemetry"]["chase_lock_status"] == "LOCKED" else 'red'
            size = 60 + kappa * 8

            self.ax.scatter([x], [y], [z], c=color, s=size, alpha=0.85, edgecolors='black')

            # Label high-κ nodes
            if kappa > 5.0:
                self.ax.text(x, y, z+0.3, f"κ{kappa:.1f}", fontsize=9)

        return self.scat,

    def start_animation(self):
        ani = FuncAnimation(self.fig, self.update, interval=380, blit=False, cache_frame_data=False)
        plt.show()


# ====================== MATRIX WITH INTEGRATED VIZ ======================
class DualRingTordialMatrix:
    def __init__(self, node_count: int = 8, base_d: int = 38, base_r: int = 340, db_path="tordial_gs.db"):
        self.node_count = node_count
        self.BASE_FREQUENCY_HZ = 79.0
        self.MIN_FREQUENCY_FLOOR_HZ = 48.0
        self.current_filtered_frequency_hz = self.BASE_FREQUENCY_HZ
        self.current_tick = 0
        self.t_start = time.time()
        self.active_ring = "RING_A"
        self.current_snapshots = []

        self.ledger_db = TordialSQLiteLedger(db_path)

        # Heterogeneous nodes
        self.nodes_a = [TordialNode(base_d + i*3, base_r + i*18) for i in range(node_count)]
        self.nodes_b = [TordialNode(base_d + i*3, base_r + i*18) for i in range(node_count)]

        self.quarantined_a = set()
        self.quarantined_b = set()
        self.consec_drift_a = {i: 0 for i in range(node_count)}
        self.consec_drift_b = {i: 0 for i in range(node_count)}

        self.visualizer = TordialLiveVisualizer(self)

    def execute_governance_cycle(self):
        self.current_tick += 1
        t_now = time.time() - self.t_start
        snapshots_a = []
        snapshots_b = []

        for i in range(self.node_count):
            rep_a = self.nodes_a[i].run_step(t_now, 0.01 if i not in self.quarantined_a else 0.25)
            if i in self.quarantined_a: rep_a["chase_lock_status"] = "QUARANTINED"
            snapshots_a.append({"node_index": i, "telemetry": rep_a})

            rep_b = self.nodes_b[i].run_step(t_now, 0.01 if i not in self.quarantined_b else 0.25)
            if i in self.quarantined_b: rep_b["chase_lock_status"] = "QUARANTINED"
            snapshots_b.append({"node_index": i, "telemetry": rep_b})

        self._evaluate_health(snapshots_a, self.quarantined_a, self.consec_drift_a, "A")
        self._evaluate_health(snapshots_b, self.quarantined_b, self.consec_drift_b, "B")

        # Failover logic...
        if self.active_ring == "RING_A" and (self.node_count - len(self.quarantined_a)) < 3:
            self.active_ring = "RING_B"

        targeted = snapshots_a if self.active_ring == "RING_A" else snapshots_b
        self.current_snapshots = targeted   # For visualizer

        # GS-aware PID update (same logic as before)
        drifting = sum(1 for s in targeted if s["telemetry"]["chase_lock_status"] == "DRIFTING")
        active_count = self.node_count - len(self.quarantined_a if self.active_ring == "RING_A" else self.quarantined_b)
        avg_kappa = np.mean([s["telemetry"]["coupling_telemetry"]["kappa_GS_T"] 
                            for s in targeted if s["telemetry"]["coupling_telemetry"]]) or 0.0

        strength_factor = min(1.0, 0.52 + avg_kappa * 0.65)
        target_freq = self.BASE_FREQUENCY_HZ if drifting == 0 else \
                      self.BASE_FREQUENCY_HZ - (self.BASE_FREQUENCY_HZ - self.MIN_FREQUENCY_FLOOR_HZ) * \
                      (drifting / active_count) * (1 - strength_factor)

        self.current_filtered_frequency_hz = max(45.0, min(92.0, target_freq))

    def _evaluate_health(self, snapshots, quarantined, consec, ring):
        # (same logic as previous versions)
        for entry in snapshots:
            idx = entry["node_index"]
            if idx in quarantined: continue
            status = entry["telemetry"]["chase_lock_status"]
            coupling = entry["telemetry"]["coupling_telemetry"]
            if status == "DRIFTING":
                penalty = 0.55 if (coupling and coupling["kappa_GS_T"] > 4.5) else 1.0
                consec[idx] += penalty
                if consec[idx] >= 5.0:
                    quarantined.add(idx)
            else:
                consec[idx] = max(0, consec[idx] - 1.3)


