# ====================== CLI ======================
def main():
    parser = argparse.ArgumentParser(description="Tordial-GS Manifold v7")
    parser.add_argument("--nodes", type=int, default=8, help="Number of nodes")
    parser.add_argument("--cycles", type=int, default=120, help="Simulation cycles")
    parser.add_argument("--video", type=str, default=None, help="Save animation as video (e.g. tordial_run.mp4)")
    parser.add_argument("--analysis", action="store_true", help="Run post-analysis only")
    args = parser.parse_args()

    if args.analysis:
        run_post_analysis()
        return

    matrix = DualRingTordialMatrix(
        node_count=args.nodes,
        record_video=bool(args.video)
    )

    matrix.run(cycles=args.cycles, video_path=args.video)
    run_post_analysis()


if __name__ == "__main__":
    main()