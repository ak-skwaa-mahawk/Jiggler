+        CREATE TABLE IF NOT EXISTS nodes (
+            node_id INTEGER PRIMARY KEY,
+            d INTEGER,
+            r INTEGER,
+            sigma_T REAL,
+            drift_phase REAL,
+            fission_count INTEGER,
+            parent_id INTEGER,
+            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
