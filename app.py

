import streamlit as st
import time
import yaml
import numpy as np
import plotly.graph_objects as go
from datetime import datetime

st.set_page_config(page_title="Tordial-GS Manifold", layout="wide")
st.title("Tordial–GS Manifold Live Control Fabric")

# Load config
with open("config.yaml") as f:
    config = yaml.safe_load(f)

# Sidebar controls
st.sidebar.header("Controls")
node_count = st.sidebar.slider("Number of Nodes", 4, 20, config["simulation"]["default_nodes"])
cycles = st.sidebar.slider("Simulation Cycles", 50, 500, 200)
run_button = st.sidebar.button("▶️ Start / Resume Manifold")
pause = st.sidebar.button("⏸️ Pause")
reset = st.sidebar.button("Reset")

# Main dashboard
col1, col2 = st.columns([3, 2])

with col1:
    st.subheader("Live Toroidal Manifold")
    plot_placeholder = st.empty()

with col2:
    st.subheader("Telemetry")
    freq_placeholder = st.empty()
    kappa_placeholder = st.empty()
    status_placeholder = st.empty()

# Simple simulation state
if "matrix" not in st.session_state:
    st.session_state.matrix = None
    st.session_state.running = False
    st.session_state.tick = 0

if run_button:
    st.session_state.running = True

# Mock live loop (replace with actual matrix integration)
if st.session_state.running:
    for _ in range(8):  # update in bursts
        # Simulate data
        t = time.time()
        phases = np.linspace(0, 2*np.pi, node_count) + t
        kappas = np.random.uniform(4.5, 8.2, node_count)
        
        # 3D Plotly Torus
        fig = go.Figure()
        for i in range(node_count):
            phase = phases[i]
            x = (3.3 + 1.15 * np.cos(i * 0.78)) * np.cos(phase)
            y = (3.3 + 1.15 * np.cos(i * 0.78)) * np.sin(phase)
            z = 1.15 * np.sin(i * 0.78)
            color = "lime" if np.random.rand() > 0.3 else "red"
            fig.add_trace(go.Scatter3d(x=[x], y=[y], z=[z], mode='markers',
                                     marker=dict(size=8 + kappas[i], color=color)))
        
        fig.update_layout(title=f"Tick {st.session_state.tick} | Freq: 78.4 Hz", 
                         scene=dict(xaxis=dict(range=[-6,6]), yaxis=dict(range=[-6,6]), zaxis=dict(range=[-4,4])))
        
        plot_placeholder.plotly_chart(fig, use_container_width=True)
        
        freq_placeholder.metric("Current Frequency", f"{78.2 + np.random.randn():.2f} Hz", "Stable")
        kappa_placeholder.metric("Avg κ_GS_T", f"{np.mean(kappas):.2f}", "Strong")
        
        st.session_state.tick += 1
        time.sleep(0.25)

